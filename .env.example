#
# Copy this file to .env for local development only.
# Replace every password, secret, and token before any shared or production deployment.
#
POSTGRES_DB=wbs_platform
POSTGRES_USER=wbs
POSTGRES_PASSWORD=wbs_dev_password
OPENPROJECT_SECRET_KEY_BASE=change-me-development-secret-key-base-please-replace-before-production-2026-06-01-wbs-platform-openproject
OPENPROJECT_HOST_NAME=localhost:8080
OPENPROJECT_ADMIN_PASSWORD=adminadmin
OPENPROJECT_SYNC_ENABLED=false
OPENPROJECT_API_TOKEN=
OPENPROJECT_AUTH_MODE=bearer
OPENPROJECT_DEFAULT_TYPE_ID=
OPENPROJECT_TYPE_MAP_JSON={}
OPENPROJECT_SYNC_PARENT_LINKS=true
PM_ENGINE_ADAPTER=openproject

# Development-only convenience aliases.
# Keep this disabled for shared, staging, and production deployments.
WBS_ENABLE_LOGIN_ALIASES=false
# Example only:
# WBS_LOGIN_ALIASES_JSON={"admin":{"username":"admin","password":"replace-with-a-long-local-only-password"}}
WBS_LOGIN_ALIASES_JSON=

# Security and WBS validation policy.
WBS_PASSWORD_MIN_LENGTH=8
WBS_PASSWORD_REQUIRE_NUMBER=true
WBS_PASSWORD_REQUIRE_SPECIAL=false
WBS_PASSWORD_REQUIRE_UPPER=false
WBS_STRICT_WEIGHT_VALIDATION=true

WBS_API_PORT=8000
WBS_PORTAL_PORT=3010
PROMETHEUS_PORT=9090
POSTGRES_EXPORTER_PORT=9187
